# Leave the credential fields blank for a local, offline demo first launch.
# The optional “Fetch public live markets” button does not use these credentials.
# Set prod to search public production markets; private account data still needs credentials.
KALSHI_ENV=prod
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=./kalshi_private.key
DATABASE_URL=sqlite:///./kalshi_dashboard.db

# Login protection.
# Local first launch can stay false. For Render/cloud, set this to true and
# put a strong password in APP_PASSWORD using Render Environment Variables.
APP_AUTH_REQUIRED=false
APP_USERNAME=admin
APP_PASSWORD=

# Maximum number of public open markets to store and search locally.
SNAPSHOT_LIMIT=2500
# The Explorer catalogue can be larger than a single snapshot batch.
PUBLIC_MARKET_LIMIT=10000
SNAPSHOT_INTERVAL_MINUTES=5
